{
    "name": "mba-dsa",
    "image": "lucasvmigotto/devenv:python-3.14-trixie",
    "runArgs": [
        "--env-file", ".env"
    ],
    "mounts": [
        {
            "source": "mba-dsa-dependencies",
            "target": "/home/developer/.venv",
            "type": "volume"
        },
        {
            "source": "mba-dsa-hf-cache",
            "target": "/home/developer/.hf",
            "type": "volume"
        },
        {
            "source": "devcontainer-extensions",
            "target": "/root/.vscode-server/extensions",
            "type": "volume"
        }
    ],
    "features": {
        "ghcr.io/devcontainers/features/node": {}
    },
    "initializeCommand": {
        "envfile": "[ ! -f '.env' ] && cp .env.example .env || echo '.env already exists'"
    },
    "postCreateCommand": {
        "nodemon": "npm i -g nodemon"
    },
    "updateContentCommand": "[ -f './pyproject.toml' ] && uv sync --all-groups --all-extras || echo 'pyproject.toml not detected'",
    "customizations": {
        "vscode": {
            "settings": {
                "remote.autoForwardPorts": true,
                "python.defaultInterpreterPath": "~/.venv",
                "python.analysis.diagnosticSeverityOverrides": {
                    "reportAttributeAccessIssue": "warning",
                    "reportAssignmentType": "warning"
                },
                "python.languageServer": "None",
                "[python]": {
                    "diffEditor.ignoreTrimWhitespace": false,
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "editor.codeActionsOnSave": {
                    "source.organizeImports.ruff": "explicit"
                }
            },
            "extensions": [
                // Development
                "almenon.arepl",
                "charliermarsh.ruff",
                // Environment
                "Cardinal90.multi-cursor-case-preserve",
                "ryu1kn.partial-diff",
                "christian-kohler.path-intellisense",
                "JannisX11.batch-rename-extension",
                "njzy.stats-bar",
                // Utils
                "mhutchie.git-graph",
                "fill-labs.dependi",
                "github.vscode-github-actions",
                // Style and formatting
                "DavidAnson.vscode-markdownlint",
                "mohsen1.prettify-json",
                "EditorConfig.EditorConfig",
                "astral-sh.ty",
                "tamasfe.even-better-toml",
                // Language
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-portuguese-brazilian"
            ]
        }
    }
}
